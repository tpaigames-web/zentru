# Supabase (required) ---------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI Receipt OCR (optional) ----------------------------------------------------
# DO NOT put GEMINI_API_KEY here — it must live in the Supabase Edge Function
# secrets, not the client bundle.
#
# Setup:
#   1. Get a free key from https://aistudio.google.com/app/apikey
#   2. Supabase Dashboard → Edge Functions → Secrets → Add:
#        Name:  GEMINI_API_KEY
#        Value: <your-key>
#   3. Deploy:  npx supabase functions deploy scan-receipt
#   4. Run SQL: supabase/ai-scan.sql (adds quota column + RPCs)
